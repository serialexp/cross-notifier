#!/bin/sh
# ABOUTME: Pre-commit hook that runs Rust formatting and lint checks.
# ABOUTME: Mirrors what CI runs (cargo fmt --check, cargo clippy -D warnings).

set -e

echo "Running pre-commit checks..."

if command -v just >/dev/null 2>&1; then
    # `just lint` runs clippy across the workspace with -D warnings.
    just lint
    # Format check (no dedicated `just` recipe yet; use cargo directly).
    cargo fmt --all -- --check
else
    echo "Checking formatting..."
    cargo fmt --all -- --check

    echo "Running clippy..."
    cargo clippy --workspace --all-targets -- -D warnings
fi

echo "Pre-commit checks passed!"
